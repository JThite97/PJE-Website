# ✅ FIXED: Complete environment variable documentation

# VITE_SITE_URL: The public URL where this site is deployed.
# Used for canonical URLs, Open Graph tags, and SEO meta tags.
# Example: https://pjenterprise.in
VITE_SITE_URL="https://pjenterprise.in"

# VITE_WEB3FORMS_KEY: (Optional) API key from web3forms.com for contact form emails.
# Visit https://web3forms.com, enter your email, and get your free access key.
# Required only when contact form email integration is enabled.
# VITE_WEB3FORMS_KEY="your-web3forms-access-key"
